@PointClass base(Weapon) appliesto(EP1, EP2, HL2, P1)
	studioprop("models/weapons/w_bugbait.mdl") = weapon_bugbait: "Sticky spores that attract Antlions.\n\n" +
		"This weapon can only function if global state condition \"Antlions are player allies\" is active."
	[
	@resources
		[
		weapon_script "scripts/weapon_bugbait.txt"
		sound "Weapon_Bugbait.Splat" // Squeeze!
		entity npc_grenade_bugbait
		]
	]
