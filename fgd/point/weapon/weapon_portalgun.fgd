@PointClass base(Weapon) 
	appliesto(P1, P2, -STANLEY) 
	// Don't add a subfolder to this, Portal maps won't contain any other weapons.
	autovis(Weapons)
	studioprop[-P2CE]("models/weapons/w_portalgun.mdl") 
	studioprop[+P2CE]()
= weapon_portalgun: "Aperture Science Handheld Portal Device"
	[
	canfireportal1(boolean) : "Can Fire Blue Portals" : 1 : "Determines whether this portal gun can shoot blue portals."
	canfireportal2(boolean) : "Can Fire Orange Portals" : 1 : "Determines whether this portal gun can shoot orange portals."
	
	showingpotatos[P2](boolean) : "Show PoTaToS" : 0 : "Attach PotatOS to the portal gun by enabling its respective bodygroup. PotatOS will animate if the @glados entity is given a VCD to play."

	startingteamnum[engine](integer) : "Player" : 0 : "Which player this gun belongs to.  Will decide which portals it fires before being picked up, as well as the skin."
	startingteamnum[P2](choices) : "Player" : 0 : "Which player this gun belongs to.  Will decide which portals it fires before being picked up, as well as the skin." =
		[
		0: "Singleplayer/Unassigned"
		2: "P-Body"
		3: "ATLAS"
		]


	skin[engine](integer) : "Stripes" : 0 : "Which stripes to show in Hammer."
	skin[P2, -P2CE](choices) : "Stripes" : 0 : "Determines which stripes to show on the world model before being picked up.." =
		[
		0: "None"
		1: "Blue"
		2: "Orange"
		]
	skin[P2CE](choices) : "Model Skin" : 0 :"Changes the world and view model skin for this entity. If no custom model is declared, this will determine what portal gun stripes to use." =
		[
		0: "0 - Default"
		1: "1 - Atlas (Coop)"
		2: "2 - P-body (Coop)"
		]

	model[P2CE](studio): "World Model" : "models/weapons/w_portalgun.mdl" : "The model shown for the portalgun entity and in the player's hand in third-person view."
	viewmodel[P2CE](studio): "View Model" : "models/weapons/v_portalgun.mdl" : "The model shown in the player's first-person view."
	CustomPortalColors[P2CE](boolean): "Custom Portal Colors" : 0 : "Use custom portal colors. This boolean is ignored if ConVar cl_alternate_portal_colors is set to 1."
	Portal1Color[P2CE](color255): "Primary Portal Color" : "64 160 255" : "Color to use for the primary (Left/Blue) portal."
	Portal2Color[P2CE](color255): "Secondary Portal Color" : "255 160 32" : "Color to use for the primary (Right/Orange) portal."
 

	// Inputs
	input ChargePortal1[P1](void) : "Does charge up effect for mounted portalgun."
	input ChargePortal1[P2](void) : "Does charge up effect for mounted portalgun. Missing particles and sounds."
	input ChargePortal2[P1](void) : "Does charge up effect for mounted portalgun."
	input ChargePortal2[P2](void) : "Does charge up effect for mounted portalgun. Missing particles and sounds."
	input FirePortal1(void) : "Projects the	'blue' portal onto a wall in the facing direction of the gun."
	input FirePortal2(void) : "Projects the 'orange' portal onto a wall in the facing direction of the gun."
	input FirePortalDirection1(vector) : "Fires the 'blue' portal in the specified direction."
	input FirePortalDirection2(vector) : "Fires the 'orange' portal in the specified direction."

	// Outputs
	output OnFiredPortal1(void) : "Fires when the 'blue' portal is fired."
	output OnFiredPortal2(void) : "Fires when the 'orange' portal is fired."
	]
