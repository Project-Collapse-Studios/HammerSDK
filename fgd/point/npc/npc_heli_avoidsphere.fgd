@PointClass base(BaseEntityPoint) 
	appliesto(EP1, EP2, HL2, P1, ASW) 
	iconsprite("editor/npc_heli_avoidsphere") 
	color(255 255 0) 
	sphere(radius)
= npc_heli_avoidsphere: "Makes Combine helicopters and gunships avoid this area."
	[
	spawnflags(flags) : "spawnflags" =
		[
		65536: "Avoid the sphere above and below" : 0
		]

	radius(float) : "Radius" : 128 : "The radius of the avoidance sphere."

	@resources []
	]
