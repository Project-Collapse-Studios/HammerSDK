@PointClass base(npc_template_maker) 
	appliesto(EP1, EP2, HL2, P1) 
	autovis(Templates, Hunter Maker)
	iconsprite("editor/vizzys/npc_hunter_maker.vmt") 
= npc_hunter_maker: "A specialized version of npc_template_maker that spawns Hunters. Hunters spawned by this entity will be forced to assemble in packs and follow their assigned Strider."
	[
	@resources [] // Hunter is a template, so it has to be in the map.
	]
